<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- BLE (Phase 1: IdoBleClient) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- Health Connect permissions -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <!-- Android 14+: 백그라운드에서 Health Connect 읽기 (잠금/WorkManager) -->
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND" />

    <!-- Declare Health Connect client -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:label="LongRun"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <activity
            android:name=".WebActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Health Connect permission rationale -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- 디버그용 기존 설정 화면 (숨김) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Phase 1 debug trigger:
             adb shell am broadcast -a com.technoetic.longrun.IDO_PING    -p com.technoetic.longrun.bridge
             adb shell am broadcast -a com.technoetic.longrun.IDO_HR_ON   -p com.technoetic.longrun.bridge
             adb shell am broadcast -a com.technoetic.longrun.IDO_HR_OFF  -p com.technoetic.longrun.bridge -->
        <receiver
            android:name=".IdoDebugReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.technoetic.longrun.IDO_PING" />
                <action android:name="com.technoetic.longrun.IDO_HR_ON" />
                <action android:name="com.technoetic.longrun.IDO_HR_OFF" />
                <action android:name="com.technoetic.longrun.IDO_SYNC_SWEEP" />
                <action android:name="com.technoetic.longrun.IDO_HEALTH_SYNC" />
                <action android:name="com.technoetic.longrun.IDO_DAILY" />
                <action android:name="com.technoetic.longrun.IDO_SYNC_NOW" />
                <action android:name="com.technoetic.longrun.IDO_CAT_SWEEP" />
            </intent-filter>
        </receiver>

        <!-- Alias to reuse on privacy-policy page if needed -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".WebActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
    </application>

</manifest>
